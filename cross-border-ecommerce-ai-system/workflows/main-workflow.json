      },
      "id": "call-pricing-agent",
      "name": "调用-动态定价Agent",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [1850, 400]
    },
    {
      "parameters": {
        "workflowId": "={{$workflow.id}}_inventory",
        "options": {
          "waitForSubWorkflow": true
        }
      },
      "id": "call-inventory-agent",
      "name": "调用-库存管理Agent",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [1850, 600]
    },
    {
      "parameters": {
        "jsCode": "// AI决策结果聚合\nconst customerService = $('调用-智能客服Agent').all();\nconst pricing = $('调用-动态定价Agent').all();\nconst inventory = $('调用-库存管理Agent').all();\n\nconst results = [];\n\nfor (let i = 0; i < customerService.length; i++) {\n  const aggregated = {\n    order_id: customerService[i].json.order_id,\n    customer_service: customerService[i].json,\n    pricing: pricing[i]?.json || {},\n    inventory: inventory[i]?.json || {},\n    timestamp: new Date().toISOString(),\n    decision: {\n      proceed: true,\n      requires_human_review: false,\n      alerts: []\n    }\n  };\n  \n  // 决策逻辑\n  if (customerService[i].json.escalate_to_human) {\n    aggregated.decision.requires_human_review = true;\n    aggregated.decision.alerts.push('Customer service escalation');\n  }\n  \n  if (inventory[i]?.json.stock_level < 10) {\n    aggregated.decision.alerts.push('Low inventory warning');\n  }\n  \n  if (pricing[i]?.json.price_adjustment > 0.15) {\n    aggregated.decision.requires_human_review = true;\n    aggregated.decision.alerts.push('Large price adjustment detected');\n  }\n  \n  results.push({json: aggregated});\n}\n\nreturn results;"
      },
      "id": "aggregate-decisions",
      "name": "聚合AI决策",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2050, 400]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
