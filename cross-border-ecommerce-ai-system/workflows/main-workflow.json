    {
      "parameters": {
        "jsCode": "// 性能指标记录\nconst startTime = $execution.startedAt;\nconst endTime = new Date();\nconst duration = endTime - new Date(startTime);\n\nconst metrics = {\n  execution_id: $execution.id,\n  workflow_id: $workflow.id,\n  duration_ms: duration,\n  items_processed: $input.all().length,\n  success_count: $input.all().filter(i => i.json.decision?.proceed).length,\n  review_count: $input.all().filter(i => i.json.decision?.requires_human_review).length,\n  timestamp: endTime.toISOString()\n};\n\nreturn [{json: metrics}];"
      },
      "id": "performance-metrics",
      "name": "性能指标",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2650, 550]
