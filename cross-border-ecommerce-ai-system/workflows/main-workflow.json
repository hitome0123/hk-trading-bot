      "type": "n8n-nodes-base.redis",
      "typeVersion": 1,
      "position": [650, 800]
    },
    {
      "parameters": {
        "mode": "combine",
        "combinationMode": "mergeByPosition",
        "options": {}
      },
      "id": "merge-all-orders",
      "name": "合并所有订单",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2.1,
      "position": [850, 450]
    },
    {
      "parameters": {
        "jsCode": "// 数据清洗和标准化\nconst items = $input.all();\nconst standardized = [];\n\nfor (const item of items) {\n  const data = item.json;\n  \n  // 标准化订单格式\n  const order = {\n    order_id: data.id || data.orderId || data.order_number,\n    platform: data.source || 'unknown',\n    customer_id: data.customer?.id || data.buyerId,\n    items: data.items || data.lineItems || [],\n    total_amount: parseFloat(data.total || data.amount || 0),\n    currency: data.currency || 'USD',\n    status: data.status || 'pending',\n    created_at: data.created_at || data.createdAt || new Date().toISOString(),\n    shipping_address: data.shipping_address || data.shippingAddress || {},\n    metadata: {\n      raw_platform: data.source,\n      processing_timestamp: new Date().toISOString()\n    }\n  };\n  \n  standardized.push({json: order});\n}\n\nreturn standardized;"
      },
      "id": "data-cleansing",
      "name": "数据清洗标准化",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 450]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.total_amount}}",
              "operation": "larger",
              "value2": 1000
            }
          ]
        }
      },
      "id": "filter-high-value",
      "name": "筛选-高价值订单",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1250, 450]
    },
    {
